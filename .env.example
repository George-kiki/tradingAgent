# ========= DeepSeek 大模型配置 =========
# 在 https://platform.deepseek.com 申请 API Key
DEEPSEEK_API_KEY=sk-你的key
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 可选模型：deepseek-v4-pro（V4 旗舰，推荐）/ deepseek-v4-flash（更便宜更快）/ deepseek-chat（旧版，2026-07-24 废弃）
DEEPSEEK_MODEL=deepseek-v4-pro

# ========= 数据源（可选）=========
# Tushare 为可选增强数据源，不填则只用免费的 AkShare
# 在 https://tushare.pro 注册获取 token
TUSHARE_TOKEN=
# 自定义 Tushare API 地址（使用第三方代理服务时填写；官方版留空即可）
TUSHARE_API_URL=

# ========= 消息推送（可选，用于定时推送选股/复盘）=========
# 企业微信群机器人 Webhook（群设置 -> 群机器人 -> 添加 -> 复制 Webhook 地址）
WECHAT_WEBHOOK=
# 飞书自定义机器人 Webhook
FEISHU_WEBHOOK=
# 邮箱推送（SMTP）
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_TO=               # 收件人，多个用逗号分隔

# ========= 定时任务 =========
# 每日选股推送时间（24小时制 HH:MM，北京时间）
SELECT_PUSH_TIME=09:00
# 每日盘后复盘推送时间
REVIEW_PUSH_TIME=15:30
# 每日荐股推送时间（收盘后，用当日完整数据选次日票，含反思迭代）
# 18:30 龙虎榜/资金流基本齐全，数据最完整
RECOMMEND_PUSH_TIME=18:30
# 尾盘荐股推送时间（盘中推荐·尾盘买入·次日验证）
# 14:30 数据已充分定价，可行动买入至 15:00 收盘
TAIL_RECOMMEND_PUSH_TIME=14:30
# 是否启用尾盘荐股定时推送
TAIL_RECOMMEND_ENABLED=true
# 启用的推送渠道（逗号分隔）：wechat,feishu,email,console
PUSH_CHANNELS=console

# ========= 每日荐股 + 反思迭代 =========
# 每日推荐数量
REC_COUNT=5
# 胜率达标线（低于此值触发反思迭代），0.7 = 70%
REC_WINRATE=0.7
# 次日涨幅 > 此值(%) 算"赢"，0 表示次日收红即赢
REC_WIN_PCT=0.0
# 本地数据库路径
REC_DB=data_store/recommend.db
# 多维评分各维度权重系数（业绩/利好/行业景气度已调高话语权）
REC_W_VALUATION=1.0
REC_W_PERFORMANCE=1.8
REC_W_NORTHBOUND=1.0
REC_W_LHB=1.0
REC_W_VOLUME=1.0
REC_W_CATALYST=1.8
REC_W_INDUSTRY=1.6
# 每日荐股性能控制：主线板块数量/单板块候选数/总候选池/最终扫描数
REC_UNIVERSE_TOP_SECTORS=4
REC_UNIVERSE_PER_SECTOR=8
REC_UNIVERSE_MAX=30
REC_SCAN_MAX=30
# 选股趋势门槛（防逆势/背离）：硬过滤开关 / 5日动量下限 / 宁缺毋滥
REC_REQUIRE_UPTREND=true
REC_MIN_MOM5=-3
REC_STRICT_NO_FILL=true
# 资金流：true=主力净流出直接剔除（硬筛）；false=仅按净流入加减分（默认）
REC_REQUIRE_INFLOW=false

# ========= 缓存配置 =========
# 数据缓存目录与有效期（秒），默认 1 小时
CACHE_DIR=.cache
CACHE_TTL=3600

# ========= LLM 调用控制 =========
# 是否启用 LLM 分析（关闭后仅用量化策略，节省 token）
ENABLE_LLM=true
LLM_TEMPERATURE=0.3
# 多空辩论轮数
DEBATE_ROUNDS=2

# ========= Web 服务 =========
WEB_HOST=127.0.0.1
WEB_PORT=8000
